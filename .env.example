# ============================================================
# SearchAgent – Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ---- Supabase ----
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key (server-side only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Anthropic ----
# Found in: https://console.anthropic.com/settings/keys
# NEVER expose this client-side
ANTHROPIC_API_KEY=sk-ant-...

# ---- Stripe ----
# Found in: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create these in your Stripe dashboard
STRIPE_PRICE_STARTER=price_...   # 50 credits for $7.99
STRIPE_PRICE_PRO=price_...       # 150 credits for $19.99
STRIPE_PRICE_TEAM=price_...      # 500 credits for $59.99

# ---- Resend ----
# Found in: https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=briefs@yourdomain.com

# ---- App ----
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ---- Cron ----
# A random secret to protect the cron endpoint
# Generate with: openssl rand -base64 32
CRON_SECRET=your-random-secret
